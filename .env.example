# ===========================================
# VARIABLES DE ENTORNO - EJEMPLO
# ===========================================
# Copia este archivo a .env y ajusta los valores
# NO SUBAS .env a Git (está en .gitignore)
# ===========================================

# ===========================================
# CONFIGURACIÓN DE DJANGO
# ===========================================

# Modo debug (True solo en desarrollo)
DEBUG=True

# Clave secreta de Django (generar una única para producción)
# Puedes generar una con: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=django-insecure-change-this-in-production-abc123456789

# Hosts permitidos (separados por coma, sin espacios)
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ===========================================
# CONFIGURACIÓN DE POSTGRESQL
# ===========================================

# Nombre de la base de datos
POSTGRES_DB=prestamos_db

# Usuario de PostgreSQL
POSTGRES_USER=prestamos_user

# Contraseña de PostgreSQL
POSTGRES_PASSWORD=prestamos_password

# Host de la base de datos (usar 'db' para Docker Compose)
POSTGRES_HOST=db

# Puerto de PostgreSQL
POSTGRES_PORT=5432

# URL completa de conexión (alternativa a configuración individual)
DATABASE_URL=postgresql://prestamos_user:prestamos_password@db:5432/prestamos_db

# ===========================================
# CONFIGURACIÓN DE DESARROLLO
# ===========================================

# Nivel de log
LOG_LEVEL=INFO

# Zona horaria
TIME_ZONE=America/Mexico_City

# Idioma
LANGUAGE_CODE=es-mx

# ===========================================
# CONFIGURACIÓN OPCIONAL
# ===========================================

# Email backend (para desarrollo usa console)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Configuración de email (si se usa en producción)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=tu-email@gmail.com
# EMAIL_HOST_PASSWORD=tu-password

# ===========================================
# NOTAS
# ===========================================
# 1. En producción, cambia SECRET_KEY a un valor único y seguro
# 2. En producción, establece DEBUG=False
# 3. En producción, actualiza ALLOWED_HOSTS con tu dominio
# 4. Nunca compartas este archivo con valores reales en Git
